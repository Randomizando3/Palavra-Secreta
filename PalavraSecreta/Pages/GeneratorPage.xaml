<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PalavraSecreta.Pages.GeneratorPage"
    Title="Gerar">

    <ScrollView>
        <Grid Padding="16" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0"
                   Text="Cadastre palavras por tema. A lupa é sempre vermelha."
                   FontSize="12"
                   TextColor="{StaticResource Muted}" />

            <Picker x:Name="ThemePicker"
                    Grid.Row="1"
                    Title="Tema" />

            <Entry x:Name="BaseEntry"
                   Grid.Row="2"
                   Placeholder="Palavra base (ex: GELO)"
                   TextTransform="Uppercase" />

            <Entry x:Name="RevealEntry"
                   Grid.Row="3"
                   Placeholder="Palavra revelada (ex: ELO)"
                   TextTransform="Uppercase" />

            <Button Grid.Row="4"
                    Text="Adicionar"
                    Clicked="OnAdd" />

            <Label x:Name="CountLabel"
                   Grid.Row="5"
                   Text=""
                   FontSize="12"
                   TextColor="{StaticResource Muted}" />

            <Label x:Name="StatusLabel"
                   Grid.Row="6"
                   Text=""
                   FontSize="12"
                   TextColor="{StaticResource Muted}" />

            <Button Grid.Row="7"
                    Text="Ir para Jogar"
                    Clicked="OnGoGame"
                    Margin="0,10,0,0"/>
        </Grid>
    </ScrollView>

</ContentPage>
